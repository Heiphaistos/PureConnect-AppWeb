# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# Admin password (bcrypt hash)
# Generate with: node -e "const b=require('bcrypt');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$examplehashhere

# --- Cookie security ---
# Set to "true" ONLY when HTTPS is active (SSL cert deployed)
# Set to "false" when running over HTTP (no SSL yet)
COOKIE_SECURE=false

# --- Ports / URLs ---
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://vpsconnect.heiphaistos.org,http://212.227.140.45:3010

# --- Internal (set by docker-compose, override here if needed) ---
# VM_URL=http://victoriametrics:8428
# LOKI_URL=http://loki:3100
# REDIS_URL=redis://redis:6379
